---
import SectionLabel from "./SectionLabel.astro";
---

<div class="about-grid">
  <!-- Left: Photo -->
  <div class="about-photo-col" data-reveal data-delay="0">
    <div class="about-photo-frame">
      <img src="/abdullah.jpeg" alt="Abdullah Omar" class="about-photo" />
    </div>
  </div>

  <!-- Right: Content -->
  <div class="about-text-col">
    <div data-reveal data-delay="0">
      <SectionLabel text="About" />
    </div>

    <h2 class="about-headline" data-reveal data-delay="1">
      Building software that actually ships.
    </h2>

    <p class="about-body" data-reveal data-delay="2">
      I'm Abdullah Omar — a Software Engineer who builds full-stack web
      applications, AI-powered tools, and scalable backend systems.
    </p>

    <p class="about-body" data-reveal data-delay="3">
      <strong>Founding Engineer at Pyko Canada,</strong>
      <span class="muted"> where I ship LLM-driven workflows, RESTful APIs, and
      production-ready infrastructure that real users depend on every day.</span>
    </p>

    <div class="about-tags" data-reveal data-delay="4">
      <span class="about-tag">Full-Stack</span>
      <span class="about-tag">AI / LLMs</span>
      <span class="about-tag">Backend Systems</span>
    </div>
  </div>
</div>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  /* ── Photo column ── */
  .about-photo-frame {
    aspect-ratio: 3 / 4;
    border-radius: 20px;
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.09);
    position: relative;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* ── Text column ── */
  .about-headline {
    font-family: var(--font-serif);
    font-size: clamp(30px, 3.6vw, 46px);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 16px;
    margin-bottom: 28px;
  }

  .about-body {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 20px;
  }

  .about-body strong {
    font-weight: 600;
  }

  /* ── Skill tags ── */
  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .about-tag {
    font-family: var(--font-satoshi);
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    background: transparent;
    border: 1px solid rgba(29, 29, 29, 0.2);
    border-radius: 100px;
    padding: 5px 16px;
    letter-spacing: 0.01em;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .about-grid {
      grid-template-columns: 300px 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 767px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-photo-frame {
      aspect-ratio: 4 / 3;
      max-width: 320px;
    }
  }
</style>
