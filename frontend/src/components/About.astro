---
import SectionLabel from "./SectionLabel.astro";
---

<div class="about-grid">
  <!-- Left: Photo — frame slides up, image zooms out independently -->
  <div class="about-photo-col">
    <div class="about-photo-frame">
      <img src="/abdullah.jpg" alt="Abdullah Omar" class="about-photo" />
    </div>
  </div>

  <!-- Right: Content -->
  <div class="about-text-col">
    <!-- Label wipes in left→right like a stamp -->
    <div class="about-label-wrap">
      <SectionLabel text="About" />
    </div>

    <!-- Headline words slide up from masks, softer easing than Hero -->
    <h2 class="about-headline">
      <span class="word-mask"><span class="aword" style="--wi:0">Abdullah</span></span>
      <span class="word-mask"><span class="aword" style="--wi:1">Omar</span></span>
    </h2>

    <p class="about-body about-body-1">
      I started coding in 7th grade, messing around with basic HTML and CSS and deploying a website just to see if I could. What began as curiosity slowly turned into something I genuinely love building things from scratch and getting better every time.
    </p>

    <p class="about-body about-body-2">
      I've grown up between Pakistan, Vienna, and now Canada, which probably explains why I'm comfortable adapting and starting over. I'm naturally competitive, especially when it comes to soccer. I support Man City and Barcelona and rarely miss a Premier League or Champions League match. That competitive mindset carries into everything I care about.
    </p>

    <p class="about-body about-body-3">
      I'm currently studying Computer Science at the University of Toronto. Outside of building, you'll usually find me watching sports or rewatching How I Met Your Mother (still convinced it's one of the best shows ever made).
    </p>
  </div>
</div>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  /* ========================
     PHOTO — two-layer depth
     Frame + image animate independently to create parallax depth.
     ======================== */
  .about-photo-col {
    opacity: 0;
    transform: translateY(44px);
    transition: opacity 1100ms ease, transform 1100ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .about-photo-col {
    opacity: 1;
    transform: translateY(0);
  }

  .about-photo-frame {
    aspect-ratio: 3 / 4;
    border-radius: 20px;
    overflow: hidden;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.09);
    position: relative;
  }

  .about-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Starts zoomed in, settles to natural size as the frame arrives */
    transform: scale(1.14);
    transition: transform 1700ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .about-photo {
    transform: scale(1);
  }

  /* ========================
     SECTION LABEL — clip-path wipe
     Pill is stamped in left→right like a print reveal.
     ======================== */
  .about-label-wrap {
    clip-path: inset(0 101% 0 0);
    transition: clip-path 650ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .about-label-wrap {
    clip-path: inset(0 0% 0 0);
    transition-delay: 220ms;
  }

  /* ========================
     HEADLINE — word mask, softer easing than Hero
     ======================== */
  .word-mask {
    display: inline-block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
    vertical-align: top;
  }

  .aword {
    display: inline-block;
    transform: translateY(110%);
    transition-property: transform;
    transition-duration: 1050ms;
    /* Softer than Hero's cubic-bezier(0.16, 1, 0.3, 1) */
    transition-timing-function: cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Delays live only in active state → exit is instant */
  :global(.snapPage.isActive) .aword {
    transform: translateY(0);
    transition-delay: calc(380ms + var(--wi) * 55ms);
  }

  /* ── Text column ── */
  .about-headline {
    font-family: var(--font-serif);
    font-size: clamp(30px, 3.6vw, 46px);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-top: 16px;
    margin-bottom: 28px;
  }

  /* ========================
     BODY PARAGRAPHS — staggered fade-up
     Subordinate to headline; clean and unobtrusive.
     ======================== */
  .about-body {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 20px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 950ms ease, transform 950ms ease;
  }

  .about-body strong {
    font-weight: 600;
  }

  :global(.snapPage.isActive) .about-body-1 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 860ms;
  }

  :global(.snapPage.isActive) .about-body-2 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 1040ms;
  }

  :global(.snapPage.isActive) .about-body-3 {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 1220ms;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .about-grid {
      grid-template-columns: 300px 1fr;
      gap: 48px;
    }
  }

  @media (max-width: 767px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .about-photo-frame {
      aspect-ratio: 4 / 3;
      max-width: 320px;
    }
  }
</style>
