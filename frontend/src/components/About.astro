---
import SectionLabel from "./SectionLabel.astro";
---

<div class="about-wrap">
  <div data-reveal data-delay="0">
    <SectionLabel text="About" />
  </div>

  <h2 class="about-headline" data-reveal data-delay="1">
    Building software<br />that actually ships.
  </h2>

  <div class="about-content">
    <p class="about-text-large" data-reveal data-delay="2">
      I'm Abdullah Omar — a Software Engineer who builds full-stack web applications,
      AI-powered tools, and scalable backend systems.
    </p>

    <p class="about-text-large" data-reveal data-delay="3">
      <strong>Founding Engineer at Pyko Canada,</strong>
      <span class="muted">
        where I ship LLM-driven workflows, RESTful APIs, and production-ready
        infrastructure that real users depend on every day.
      </span>
    </p>
  </div>

  <div class="about-stats">
    <div class="stat card" data-reveal data-delay="4">
      <span class="stat-number accent">3+</span>
      <span class="stat-label">Years Building</span>
    </div>

    <div class="stat card" data-reveal data-delay="5">
      <span class="stat-number accent">10+</span>
      <span class="stat-label">Projects Shipped</span>
    </div>

    <div class="stat card" data-reveal data-delay="6">
      <span class="stat-number accent">8+</span>
      <span class="stat-label">Technologies</span>
    </div>
  </div>
</div>

<style>
  .about-wrap {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .about-headline {
    font-family: var(--font-serif);
    font-size: clamp(31px, 3.9vw, 44px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 32px;
  }

  .about-content {
    margin-bottom: 40px;
  }

  .about-text-large {
    font-family: var(--font-serif);
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }

  .about-text-large strong {
    font-weight: 600;
  }

  .about-stats {
    display: flex;
    gap: 48px;
    padding: 28px 36px;
    max-width: 480px;
    margin: 0 auto;
    justify-content: center;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: 31px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 14px;
    color: var(--text);
  }

  @media (max-width: 767px) {
    .about-stats {
      gap: 24px;
      padding: 22px 24px;
      max-width: 100%;
    }

    .stat-number {
      font-size: 26px;
    }
  }
</style>
