<div class="cta-wrap" data-reveal data-delay="0">
  <span class="cta-eyebrow">Contact</span>
  <h2 class="cta-heading">
    Let's build something<br>
    <em>great together.</em>
  </h2>
  <p class="cta-sub">Open to new projects, collabs, and conversations.</p>
  <a href="mailto:abdullahom07@gmail.com" class="cta-btn">
    Send me a message <span class="cta-arrow" aria-hidden="true">→</span>
  </a>
</div>

<style>
  .cta-wrap {
    padding: 56px 0 40px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-eyebrow {
    font-family: var(--font-satoshi);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 28px;
  }

  .cta-heading {
    font-family: var(--font-serif);
    font-size: clamp(50px, 6.5vw, 86px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 22px;
  }

  .cta-heading em {
    font-style: italic;
    font-weight: 300;
    color: var(--accent);
  }

  .cta-sub {
    font-family: var(--font-satoshi);
    font-size: 16px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 360px;
    margin-bottom: 44px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 50px;
    padding: 0 28px;
    background: var(--accent);
    color: #fff;
    border-radius: 100px;
    font-family: var(--font-satoshi);
    font-size: 15px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .cta-btn:hover {
    opacity: 0.82;
  }

  .cta-arrow {
    display: inline-block;
    transition: transform 0.2s;
  }

  .cta-btn:hover .cta-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 767px) {
    .cta-wrap {
      padding: 32px 0 24px;
    }
  }
</style>
