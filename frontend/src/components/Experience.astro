---
import SectionLabel from "./SectionLabel.astro";

const jobs = [
  {
    role: "Founding Engineer at Pyko Canada Ltd",
    description: "Building LLM-driven workflows, RESTful APIs, and production-ready infrastructure that real users depend on every day.",
    stack: ["Python", "TypeScript", "FastAPI", "MongoDB Atlas", "AWS"],
    period: "June 2025 – Present",
    preview: "/pyko2.JPG",
  },
  {
    role: "Freelance & Enterprise Designer",
    description: "Delivered high-quality visual assets, motion graphics, and brand identities for clients across multiple industries.",
    stack: ["Photoshop", "Blender", "Premiere Pro", "After Effects", "DaVinci Resolve"],
    period: "2022 – 2024",
    preview: "/assets/polaroid-1.jpg",
  },
  {
    role: "Research & Design Volunteer at Ethiopiaid",
    description: "Created marketing materials and research assets to support charitable outreach campaigns.",
    stack: ["Photoshop", "Canva"],
    period: "Jun 2022 – Aug 2022",
    preview: "/assets/polaroid-2.jpg",
  },
];
---

<div class="experience-wrap">
  <div data-reveal data-delay="0">
    <SectionLabel text="Experience" />
  </div>

  <h2 class="experience-heading" data-reveal data-delay="1">
    Building Real Products, Shipping Real Impact
  </h2>

  <div class="experience-list">
    {jobs.map((job, i) => (
      <div class="experience-card" data-reveal data-delay={String(i + 2)}>
        {job.preview && (
          <div class="experience-preview">
            <img src={job.preview} alt="" />
            <button class="experience-arrow" aria-label="View">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        )}
        <div class="experience-info">
          <span class="experience-role">{job.role}</span>
          <p class="experience-desc">{job.description}</p>
          <div class="experience-tags">
            {job.stack.slice(0, 3).map(tag => (
              <span class="experience-tag">{tag}</span>
            ))}
            {job.stack.length > 3 && (
              <span class="experience-tag">+{job.stack.length - 3}</span>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .experience-wrap {
    height: calc(100svh - 270px);
    display: flex;
    flex-direction: column;
    width: 100%;
    text-align: center;
  }

  .experience-heading {
    font-size: clamp(24px, 3.1vw, 38px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    white-space: nowrap;
    margin: 0 auto 24px;
  }

  .experience-list {
    display: flex;
    flex-direction: row;
    gap: 16px;
    max-width: 100%;
    margin: 0 auto;
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    align-items: stretch;
    flex: 1;
  }

  .experience-list::-webkit-scrollbar {
    display: none;
  }

  .experience-card {
    flex: 1 1 0;
    border-radius: 20px;
    padding: 0;
    display: flex;
    flex-direction: column;
    text-align: left;
    background: #232323;
    overflow: hidden;
  }

  .experience-preview {
    position: relative;
    width: 100%;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    margin-bottom: 0;
  }

  .experience-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .experience-arrow {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 35px;
    height: 35px;
    background: #fff;
    border: none;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1D1D1D;
    flex-shrink: 0;
  }

  .experience-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px 20px 20px;
  }

  .experience-role {
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.6vw, 21px);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1.2;
  }

  .experience-desc {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.55;
    margin: 0;
  }

  .experience-tags {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    margin-top: 4px;
    overflow: hidden;
  }

  .experience-tag {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.75);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    padding: 4px 12px;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .experience-wrap {
      height: auto;
    }
    .experience-list {
      flex: none;
    }
    .experience-card {
      flex: 0 0 72vw;
      min-height: 420px;
    }
  }
</style>
