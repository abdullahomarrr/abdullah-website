<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <a href="#" class="footer-brand" data-scroll-top>Abdullah.</a>
      <a href="mailto:abdullahom07@gmail.com" class="link-underline footer-email">
        abdullahom07@gmail.com
      </a>
    </div>
    <div class="footer-bottom">
      <div class="footer-socials">
        <a href="#" class="social-link">Twitter</a>
        <a href="#" class="social-link">Dribbble</a>
        <a href="#" class="social-link">Behance</a>
        <a href="#" class="social-link">LinkedIn</a>
