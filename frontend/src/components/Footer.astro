<div class="footer-inner">
  <a href="#hero" class="footer-back" data-scroll-top>
    Back to top <span>↑</span>
  </a>
</div>

<style>
  .footer-inner {
    position: absolute;
    bottom: 20px;
    left: 40px;
    right: 40px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* ========================
     BACK TO TOP — slides in from right
     Lives bottom-right, so it arrives from that direction.
     The last element to appear — a quiet coda to the whole page.
     ======================== */
  .footer-back {
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    opacity: 0;
    transform: translateX(22px);
    transition: opacity 700ms ease, transform 700ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .footer-back {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 1400ms;
  }

  .footer-back:hover {
    opacity: 0.6;
  }

  @media (max-width: 767px) {
    .footer-inner {
      left: 24px;
      right: 24px;
      bottom: 16px;
    }
  }
</style>
