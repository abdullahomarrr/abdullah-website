      <a href="#" class="footer-back" data-scroll-top>
        Back to top <span>↑</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 60px 0 40px;
    margin-top: var(--section-gap);
  }

  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .footer-brand {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 24px;
    letter-spacing: -0.01em;
  }

  .footer-email {
    font-size: 15px;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-socials {
    display: flex;
    gap: 28px;
  }

  .social-link {
    font-size: 15px;
    font-weight: 400;
    color: var(--text);
    transition: opacity 0.2s;
  }

  .social-link:hover {
    opacity: 0.6;
  }

  .footer-back {
    font-size: 15px;
    font-weight: 400;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s;
  }

  .footer-back:hover {
    opacity: 0.6;
  }

  @media (max-width: 767px) {
    .footer-top,
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
