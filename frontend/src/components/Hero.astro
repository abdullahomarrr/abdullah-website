</div>

<style>
  .hero-inner {
    max-width: 800px;
    text-align: left;
    width: 100%;
  }

  .hero-headline {
    position: relative;
    margin-bottom: 40px;
  }

  .hero-headline h1 {
    font-family: var(--font-serif);
    font-size: clamp(66px, 8.2vw, 114px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    position: relative;
  }

  .hero-subtitle {
    font-size: 20px;
    line-height: 1.65;
    color: var(--text);
    max-width: 600px;
    margin: 0 0 40px;
    text-align: left;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    justify-content: flex-start;
  }

  .hero-buttons .btn {
    height: 52px;
    padding: 0 28px;
    font-size: 17px;
  }

  .hero-bottom {
    display: flex;
    align-items: center;
  }

  .hero-discover {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s;
  }

  .hero-discover:hover {
    opacity: 0.6;
  }

  .discover-arrow {
    font-size: 16px;
  }

  @media (max-width: 767px) {
    .hero-buttons {
      flex-wrap: wrap;
    }
  }
</style>
