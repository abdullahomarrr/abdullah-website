<section class="hero">
  <div class="container" style="width: 100%;">
    <div class="hero-inner">
    <div class="hero-headline">
      <h1>
        Hi, I'm Abdullah
        <br />Omar <span class="accent">a Software</span>
        <br /><span class="accent">Engineer.</span>
      </h1>
    </div>

    <p class="hero-subtitle">
      A software engineer with hands-on experience,
      consistently delivering innovative and user-centered solutions.
    </p>

    <div class="hero-buttons">
      <a href="mailto:abdullahom07@gmail.com" class="btn btn-primary">Talk with me</a>
      <a href="#" class="btn btn-secondary">Download my cv</a>
    </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 85vh;
    display: flex;
    align-items: center;
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    text-align: left;
    width: 100%;
  }

  .hero-headline {
    position: relative;
    margin-bottom: 40px;
  }

  .hero-headline h1 {
    font-family: var(--font-serif);
    font-size: clamp(66px, 8.2vw, 114px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    position: relative;
  }

  .hero-avatar-inline {
    display: inline-block;
    vertical-align: middle;
    position: relative;
    top: -4px;
    margin-left: 8px;
  }

  .hero-avatar {
    width: clamp(64px, 6vw, 88px);
    height: clamp(64px, 6vw, 88px);
    object-fit: cover;
    border-radius: 16px;
    transform: rotate(-10deg);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    filter: grayscale(100%);
  }

  .hero-subtitle {
    font-size: 20px;
    line-height: 1.65;
    color: var(--text);
    max-width: 600px;
    margin: 0 0 40px;
    text-align: left;
  }

  .hero-buttons {
    display: flex;
    gap: 16px;
    margin-bottom: 0;
    justify-content: flex-start;
  }

  .hero-buttons .btn {
    height: 52px;
    padding: 0 28px;
    font-size: 17px;
  }

  .hero-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 20px;
  }

  .hero-socials {
    display: flex;
    gap: 28px;
  }

  .social-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    transition: opacity 0.2s;
  }

  .social-link:hover {
    opacity: 0.6;
  }

  .hero-discover {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 6px;
    transition: opacity 0.2s;
  }

  .hero-discover:hover {
    opacity: 0.6;
  }

  .discover-arrow {
    font-size: 16px;
  }

  @media (max-width: 767px) {
    .hero {
      padding-top: 40px;
    }

    .hero-buttons {
      margin-bottom: 48px;
    }

    .hero-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }
</style>
