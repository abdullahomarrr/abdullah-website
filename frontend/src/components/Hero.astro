<style>
  /* ========================
     LAYOUT
     ======================== */
  :global(.snapPage--hero .pageInner) {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100vh - 76px);
    padding-top: 24px;
    padding-bottom: 24px;
  }

  :global(.snapPage--hero) {
    position: relative;
  }

  .hero-inner {
    max-width: 800px;
    text-align: left;
    width: 100%;
    margin: 0 auto;
  }

  .hero-headline {
    position: relative;
    margin-bottom: 40px;
  }

  .hero-headline h1 {
    font-family: var(--font-serif);
    font-size: clamp(66px, 8.2vw, 114px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    position: relative;
  }

  /* ========================
     WORD MASK — H1 cinematic slide-up
     Each word rises from below its clipping mask.
     Italic accent words also correct a skew on arrival.
     ======================== */
  .word-mask {
    display: inline-block;
    overflow: hidden;
    /* Extra room so descenders aren't clipped by overflow:hidden */
    padding-bottom: 0.1em;
    margin-bottom: -0.1em;
    /* Extra room so italic trailing glyphs aren't clipped */
    padding-right: 0.12em;
    margin-right: -0.12em;
    vertical-align: top;
  }

  .word {
    display: inline-block;
    transform: translateY(115%);
    transition-property: transform;
    transition-duration: 1350ms;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    /* --wi is set inline per word (0–5), staggers each 105ms */
    transition-delay: calc(var(--wi) * 105ms);
  }

  .word--italic {
    /* Italic words arrive with a skew that snaps straight — feels crafted */
    transform: translateY(115%) skewY(6deg);
    transition-duration: 1550ms;
  }

  :global(.snapPage.isActive) .word {
    transform: translateY(0);
  }

  :global(.snapPage.isActive) .word--italic {
    transform: translateY(0) skewY(0deg);
  }

  /* ========================
     SUBTITLE — blur-into-focus
     Arrives from a haze; contrasts with the crisp word slides above.
     ======================== */
  .hero-subtitle {
    font-family: var(--font-satoshi);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: -0.01em;
    color: var(--text);
    max-width: 600px;
    margin: 0 0 40px;
    opacity: 0;
    filter: blur(8px);
    transform: translateY(10px);
    transition: opacity 1250ms ease, filter 1250ms ease, transform 1250ms ease;
  }

  :global(.snapPage.isActive) .hero-subtitle {
    opacity: 1;
    filter: blur(0px);
    transform: translateY(0);
    transition-delay: 760ms;
  }

  /* ========================
     BUTTONS — overshoot spring + shimmer
     ======================== */
  .hero-buttons {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    justify-content: flex-start;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 1100ms cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 1100ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero-buttons .btn {
    font-family: var(--font-satoshi);
    font-weight: 500;
    letter-spacing: -0.01em;
    height: 52px;
    padding: 0 28px;
    font-size: 17px;
  }

  :global(.snapPage.isActive) .hero-buttons {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 1100ms;
  }

  /* One-time shimmer sweep on the primary CTA on arrival */
  :global(.snapPage--hero .btn-primary) {
    position: relative;
    overflow: hidden;
  }

  :global(.snapPage--hero .btn-primary::after) {
    content: '';
    position: absolute;
    top: 0;
    left: -80%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.32),
      transparent
    );
    transform: skewX(-20deg);
    opacity: 0;
  }

  :global(.snapPage--hero.isActive .btn-primary::after) {
    animation: heroShimmer 1.1s ease 1650ms forwards;
  }

  @keyframes heroShimmer {
    0%   { left: -80%; opacity: 1; }
    100% { left: 140%; opacity: 1; }
  }

  /* ========================
     SCROLL EXPLORE — late fade-in + perpetual float
     ======================== */
  .scroll-explore {
    position: absolute;
    bottom: 12px;
    right: 0;
    color: var(--text);
    border-radius: 16px;
    padding: 18px 20px 16px 20px;
    text-decoration: none;
    width: 160px;
    opacity: 0;
    /* color transition instant, opacity transition delayed */
    transition: color 0.2s, opacity 1000ms ease;
  }

  .scroll-explore:hover {
    color: var(--accent);
  }

  :global(.snapPage.isActive) .scroll-explore {
    opacity: 1;
    /* color: 0s delay, opacity: 1300ms delay */
    transition-delay: 0s, 2200ms;
    animation: heroFloat 2.8s ease-in-out 3300ms infinite;
  }

  .scroll-explore__text {
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.2;
    display: block;
    margin-top: 32px;
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-7px); }
  }

  /* ========================
     HERO SOCIALS — slide from left + underline draw
     Direction motivated by their left-anchored position.
     ======================== */
  .hero-socials {
    position: absolute;
    bottom: 20px;
    left: 40px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 28px;
  }

  .hero-socials a {
    color: var(--text);
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: normal;
    font-weight: 300;
    text-decoration: none;
    position: relative;
    opacity: 0;
    transform: translateX(-16px);
    transition: opacity 850ms ease, transform 850ms ease, color 0.2s;
  }

  /* Underline that draws in left→right after the link appears */
  .hero-socials a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 400ms ease;
  }

  .hero-socials a:hover {
    color: var(--accent);
  }

  /* Staggered entrance — delays only on active state so exit is instant */
  :global(.snapPage.isActive) .hero-socials a:nth-child(1) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 1550ms;
  }
  :global(.snapPage.isActive) .hero-socials a:nth-child(2) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 1650ms;
  }
  :global(.snapPage.isActive) .hero-socials a:nth-child(3) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 1800ms;
  }

  /* Underlines draw 110ms after their link appears */
  :global(.snapPage.isActive) .hero-socials a:nth-child(1)::after {
    transform: scaleX(1);
    transition-delay: 1650ms;
  }
  :global(.snapPage.isActive) .hero-socials a:nth-child(2)::after {
    transform: scaleX(1);
    transition-delay: 1800ms;
  }
  :global(.snapPage.isActive) .hero-socials a:nth-child(3)::after {
    transform: scaleX(1);
    transition-delay: 1950ms;
  }

  /* ========================
     RESPONSIVE
     ======================== */
  @media (max-width: 767px) {
    .hero-headline h1 {
      font-size: clamp(42px, 12vw, 66px);
    }

    .hero-headline {
      margin-bottom: 24px;
    }

    .hero-subtitle {
      font-size: 17px;
      margin-bottom: 28px;
    }

    .scroll-explore { display: none; }
    .hero-buttons { flex-wrap: wrap; }
    .hero-socials { display: none; }
  }
</style>
