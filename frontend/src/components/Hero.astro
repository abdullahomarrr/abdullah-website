<div class="hero-inner">
  <div class="hero-headline" data-reveal data-delay="0">
    <h1>
      Hi, I'm Abdullah
      <br />Omar <span class="accent">a Software</span>
      <br /><span class="accent">Engineer.</span>
    </h1>
  </div>

  <p class="hero-subtitle" data-reveal data-delay="1">
    Founding Engineer at Pyko Canada, building AI-powered
    education tools, full-stack applications, and LLM-driven workflows.
  </p>

  <div class="hero-buttons" data-reveal data-delay="2">
    <a href="mailto:abdullahom07@gmail.com" class="btn btn-primary">Talk with me</a>
    <a href="#" class="btn btn-secondary">Download my cv</a>
  </div>

  <div class="hero-bottom" data-reveal data-delay="3">
    <a href="#about" class="hero-discover">
