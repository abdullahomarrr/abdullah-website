<nav class="navbar">
  <div class="navbar-inner">
    <div class="navbar-left">
      <a href="#hero" class="navbar-brand" data-scroll-top>Abdullah.</a>
      <span class="navbar-divider">/</span>
      <ul class="navbar-links">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#reviews">Reviews</a></li>
      </ul>
    </div>

    <div class="navbar-right">
      <a href="#contact" class="navbar-contact-btn">Contact me</a>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .navbar-inner {
    width: 100%;
    padding: 0 40px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .navbar-left {
    display: flex;
    align-items: center;
    gap: 20px;
    min-width: 0;
  }

  .navbar-brand {
    font-family: 'Space Grotesk', var(--font-sans);
    font-weight: 700;
    font-size: 19px;
    color: var(--text);
    letter-spacing: -0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .navbar-divider {
    color: var(--muted);
    font-size: 16px;
    font-weight: 300;
    flex-shrink: 0;
  }

  .navbar-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .navbar-links a {
    font-family: 'Space Grotesk', var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.15s ease;
    white-space: nowrap;
  }

  .navbar-links a:hover {
    color: var(--text);
  }

  .navbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .navbar-contact-btn {
    display: inline-flex;
    align-items: center;
    height: 34px;
    padding: 0 16px;
    border-radius: 8px;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: 'Space Grotesk', var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }

  .navbar-contact-btn:hover {
    background: var(--accent);
    color: #fff;
  }

  @media (max-width: 1023px) {
    .navbar-inner {
      padding: 0 32px;
    }

    .navbar-links {
      gap: 20px;
    }
  }

  @media (max-width: 767px) {
    .navbar-inner {
      padding: 0 20px;
      gap: 16px;
    }

    .navbar-links {
      gap: 14px;
    }
  }

  /* Hide lower-priority links on small screens */
  @media (max-width: 600px) {
    .navbar-links li:nth-child(n+4) {
      display: none;
    }
  }
</style>
