<nav class="navbar">
  <div class="container">
    <div class="navbar-shell">
      <ul class="navbar-links">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#services">Services</a></li>
      </ul>

      <a href="#" class="navbar-brand" data-scroll-top>Abdullah.</a>

      <div class="navbar-actions">
        <a href="#reviews" class="navbar-secondary-link">Reviews</a>
        <a href="mailto:abdullahom07@gmail.com" class="navbar-demo-btn">
          Contact me
          <span class="demo-arrow" aria-hidden="true">
            <svg viewBox="0 0 12 12">
              <path d="M2.5 6h7m0 0-3-3m3 3-3 3" />
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    padding: 20px 0;
    position: relative;
    z-index: 100;
  }

  .navbar-shell {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 28px;
    padding: 14px 18px 14px 28px;
    min-height: 78px;
    background: #ffffff;
    border: 1px solid rgba(16, 32, 21, 0.09);
    border-radius: 24px;
    box-shadow: 0 12px 28px rgba(10, 24, 14, 0.08);
  }

  .navbar-brand {
    justify-self: center;
    font-weight: 700;
    font-size: clamp(17px, 1.5vw, 22px);
    color: #172919;
    letter-spacing: -0.02em;
    line-height: 1;
    flex-shrink: 0;
  }

  .navbar-links,
  .navbar-actions {
    display: flex;
    align-items: center;
  }

  .navbar-links {
    gap: clamp(18px, 2.2vw, 34px);
    min-width: 0;
  }

  .navbar-links a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 500;
    color: #213125;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .navbar-links a:hover {
    opacity: 0.6;
  }

  .navbar-actions {
    justify-self: end;
    justify-content: flex-end;
    gap: clamp(16px, 2vw, 28px);
  }

  .navbar-secondary-link {
    font-size: clamp(15px, 1.2vw, 18px);
    font-weight: 500;
    color: #1f2f24;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .navbar-secondary-link:hover {
    opacity: 0.6;
  }

  .navbar-demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 0 18px;
    height: 50px;
    border-radius: 14px;
    background: linear-gradient(180deg, #53c86f 0%, #41b35c 100%);
    color: #ffffff;
    font-size: clamp(14px, 1.1vw, 18px);
    font-weight: 600;
    letter-spacing: -0.01em;
    box-shadow: 0 10px 20px rgba(35, 126, 64, 0.3);
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
    white-space: nowrap;
  }

  .navbar-demo-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 24px rgba(35, 126, 64, 0.36);
    filter: saturate(1.04);
  }

  .navbar-demo-btn:active {
    transform: translateY(0);
  }

  .demo-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
  }

  .demo-arrow svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 1023px) {
    .navbar-shell {
      padding: 14px 16px 14px 20px;
      gap: 18px;
    }
  }

  @media (max-width: 900px) {
    .navbar-shell {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 18px 20px;
    }

    .navbar-brand {
      justify-self: start;
      font-size: 20px;
    }

    .navbar-actions {
      justify-self: stretch;
      justify-content: space-between;
    }
  }

  @media (max-width: 640px) {
    .navbar {
      padding: 16px 0;
    }

    .navbar-shell {
      border-radius: 20px;
      padding: 16px;
      min-height: unset;
    }

    .navbar-links {
      flex-wrap: wrap;
      row-gap: 8px;
      column-gap: 16px;
    }

    .navbar-brand {
      font-size: 18px;
    }

    .navbar-secondary-link {
      font-size: 15px;
    }

    .navbar-demo-btn {
      height: 44px;
      padding: 0 14px;
      border-radius: 12px;
      font-size: 14px;
    }

    .demo-arrow {
      width: 22px;
      height: 22px;
    }
  }

  @media (max-width: 460px) {
    .navbar-actions {
      width: 100%;
      flex-wrap: wrap;
      justify-content: flex-start;
      gap: 12px;
    }

    .navbar-demo-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
