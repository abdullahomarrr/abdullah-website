---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    title: "Pyko Canada",
    year: "2025 – Present",
    stack: "Python · TypeScript · FastAPI · MongoDB Atlas · AWS",
    description: "Pyko is an deterministic and AI-powered academic intelligence platform that predicts outcomes, optimizes study behavior, and delivers proactive insights for student success.",
    color: "#1a1a2e",
    accent: "#214BB7",
    image: "/pyko.jpg",
    link: "https://pyko.ca",
  },
  {
    title: "PakUni",
    year: "2026",
    stack: "Python · JavaScript · FastAPI · MongoDB",
    description: "MVP platform for Pakistani students to create one reusable profile and submit to multiple universities. Reduced duplicated data entry by ~78% across 5 applications.",
    color: "#214BB7",
    accent: "#4a6fd4",
    image: "/pakuni.png",
    link: "#",
  },
];
---

<div class="projects-content">
  <div data-reveal data-delay="0">
    <SectionLabel text="Projects" />
  </div>

  <h2 class="projects-heading" data-reveal data-delay="1">
    Building Products That Solve Real Problems
  </h2>

  <div class="projects-grid" data-reveal data-delay="2">
    {projects.map((p) => (
      <div class="project-tile">
        <a class="project-image-wrap" href={p.link} target="_blank" rel="noopener noreferrer" style={`background: ${p.color};`}>
          {p.image ? (
            <img src={p.image} alt={p.title} class="project-img" />
          ) : (
            <div class="project-placeholder">
              <div class="placeholder-lines">
                <div class="ph-line ph-line-wide" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-mid" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-short" style={`background: ${p.accent};`}></div>
              </div>
            </div>
          )}
          <div class="project-overlay">
            <span class="view-btn">View Project</span>
          </div>
        </a>
        <div class="project-meta">
          <span class="project-title">{p.title}</span>
          <span class="project-year muted">{p.year}</span>
        </div>
        <p class="project-description muted">{p.description}</p>
        <div class="project-tags">
          {p.stack.split(' · ').map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .projects-content {
    width: 100%;
  }

  .projects-heading {
    font-size: clamp(31px, 3.9vw, 44px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 620px;
    margin-bottom: 32px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .project-tile {
    display: flex;
    flex-direction: column;
  }

  .project-image-wrap {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 16px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition:
      filter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-image-wrap:hover .project-img {
    filter: blur(5px);
    transform: scale(1.03);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-image-wrap:hover .project-overlay {
    opacity: 1;
  }

  .view-btn {
    color: #fff;
    font-family: var(--font-satoshi);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    border-radius: 100px;
    padding: 9px 22px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s,
      transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s;
  }

  .project-image-wrap:hover .view-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .placeholder-lines {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 40%;
  }

  .ph-line {
    height: 4px;
    border-radius: 2px;
    opacity: 0.45;
  }

  .ph-line-wide  { width: 100%; }
  .ph-line-mid   { width: 70%; }
  .ph-line-short { width: 50%; }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 8px;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .project-year {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: 15px;
    flex-shrink: 0;
  }

  .project-description {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 8px;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-satoshi);
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    background: transparent;
    border: 1px solid rgba(29, 29, 29, 0.2);
    border-radius: 100px;
    padding: 3px 10px;
    letter-spacing: 0.01em;
  }

  @media (max-width: 767px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
