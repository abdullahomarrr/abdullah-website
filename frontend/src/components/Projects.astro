---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    title: "Pyko Canada",
    year: "2025 – Present",
    stack: "Python · TypeScript · FastAPI · MongoDB Atlas · AWS",
    description: "Pyko is an deterministic and AI-powered academic intelligence platform that predicts outcomes, optimizes study behavior, and delivers proactive insights for student success.",
    color: "#1a1a2e",
    accent: "#214BB7",
    image: "/pyko.jpg",
    link: "/projects/pyko",
  },
  {
    title: "PakUni",
    year: "2026",
    stack: "Python · JavaScript · FastAPI · MongoDB",
    description: "MVP platform for Pakistani students to create one reusable profile and submit to multiple universities. Reduced duplicated data entry by ~78% across 5 applications.",
    color: "#214BB7",
    accent: "#4a6fd4",
    image: "/pakuni.png",
    link: "/projects/pakuni",
  },
];
---

<div class="projects-content">
  <!-- Label slides DOWN from above — first time in the portfolio -->
  <div class="projects-label-wrap">
    <SectionLabel text="Projects" />
  </div>

  <!-- Word-mask headline: snappiest easing of the three sections -->
  <h2 class="projects-heading">
    <span class="word-mask"><span class="pword" style="--pwi:0">Building</span></span>
    <span class="word-mask"><span class="pword" style="--pwi:1">Products</span></span>
    <span class="word-mask"><span class="pword" style="--pwi:2">That</span></span>
    <span class="word-mask"><span class="pword" style="--pwi:3">Solve</span></span>
    <span class="word-mask"><span class="pword" style="--pwi:4">Real</span></span>
    <span class="word-mask"><span class="pword" style="--pwi:5">Problems</span></span>
  </h2>

  <div class="projects-grid">
    {projects.map((p) => (
      <div class="project-tile">
        <a
          class="project-image-wrap"
          href={p.link}
          target={p.link.startsWith('http') ? '_blank' : undefined}
          rel={p.link.startsWith('http') ? 'noopener noreferrer' : undefined}
          style={`background: ${p.color};`}
        >
          {p.image ? (
            /* Zoom wrapper animates independently from hover on .project-img */
            <div class="project-img-zoom">
              <img src={p.image} alt={p.title} class="project-img" />
            </div>
          ) : (
            <div class="project-placeholder">
              <div class="placeholder-lines">
                <div class="ph-line ph-line-wide" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-mid" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-short" style={`background: ${p.accent};`}></div>
              </div>
            </div>
          )}
          <div class="project-overlay">
            <span class="view-btn">View Project</span>
          </div>
        </a>
        <div class="project-meta">
          <span class="project-title">{p.title}</span>
          <span class="project-year muted">{p.year}</span>
        </div>
        <p class="project-description muted">{p.description}</p>
        <div class="project-tags">
          {p.stack.split(' · ').map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .projects-content {
    width: 100%;
  }

  /* ========================
     LABEL — slides down from above
     First element in portfolio to arrive from the top.
     ======================== */
  .projects-label-wrap {
    opacity: 0;
    transform: translateY(-14px);
    transition: opacity 700ms ease, transform 700ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .projects-label-wrap {
    opacity: 1;
    transform: translateY(0);
    /* No delay — label lands first */
  }

  /* ========================
     HEADING — word mask, snappiest of the three sections
     Hero: 0.16,1,0.3,1  |  About: 0.25,1,0.5,1  |  Projects: 0.22,1,0.36,1
     ======================== */
  .projects-heading {
    font-size: clamp(31px, 3.9vw, 44px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 620px;
    margin-bottom: 32px;
  }

  .word-mask {
    display: inline-block;
    overflow: hidden;
    padding-bottom: 0.08em;
    margin-bottom: -0.08em;
    vertical-align: top;
  }

  .pword {
    display: inline-block;
    transform: translateY(110%);
    transition-property: transform;
    transition-duration: 950ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.snapPage.isActive) .pword {
    transform: translateY(0);
    transition-delay: calc(180ms + var(--pwi) * 40ms);
  }

  /* ========================
     GRID
     ======================== */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* ========================
     CARDS — converge from opposite sides
     Card 1 slides from LEFT, Card 2 from RIGHT.
     Fast opacity (500ms), slower slide (1100ms) — card materializes as it moves.
     ======================== */
  .project-tile {
    display: flex;
    flex-direction: column;
  }

  .project-tile:nth-child(1) {
    opacity: 0;
    transform: translateX(-50px);
    transition: opacity 500ms ease, transform 1100ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .project-tile:nth-child(2) {
    opacity: 0;
    transform: translateX(50px);
    transition: opacity 500ms ease, transform 1100ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .project-tile:nth-child(1) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 650ms;
  }

  :global(.snapPage.isActive) .project-tile:nth-child(2) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 760ms;
  }

  /* ========================
     IMAGE — zoom-out wrapper
     .project-img-zoom handles the entrance scale (1.08 → 1).
     .project-img inside handles hover blur/scale independently.
     Separation prevents entrance timing from breaking the hover effect.
     ======================== */
  .project-image-wrap {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 16px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
  }

  .project-img-zoom {
    width: 100%;
    height: 100%;
    transform: scale(1.08);
    transition: transform 1600ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  :global(.snapPage.isActive) .project-tile:nth-child(1) .project-img-zoom {
    transform: scale(1);
    transition-delay: 650ms;
  }

  :global(.snapPage.isActive) .project-tile:nth-child(2) .project-img-zoom {
    transform: scale(1);
    transition-delay: 760ms;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition:
      filter 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-image-wrap:hover .project-img {
    filter: blur(5px);
    transform: scale(1.03);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-image-wrap:hover .project-overlay {
    opacity: 1;
  }

  .view-btn {
    color: #fff;
    font-family: var(--font-satoshi);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border: 1.5px solid rgba(255, 255, 255, 0.75);
    border-radius: 100px;
    padding: 9px 22px;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s,
      transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s;
  }

  .project-image-wrap:hover .view-btn {
    opacity: 1;
    transform: translateY(0);
  }

  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .placeholder-lines {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 40%;
  }

  .ph-line { height: 4px; border-radius: 2px; opacity: 0.45; }
  .ph-line-wide  { width: 100%; }
  .ph-line-mid   { width: 70%; }
  .ph-line-short { width: 50%; }

  /* ========================
     META + DESCRIPTION — fade up per card
     Delays are relative to each card's start time.
     ======================== */
  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 8px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 800ms ease, transform 800ms ease;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .project-year {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: 15px;
    flex-shrink: 0;
  }

  .project-description {
    font-family: var(--font-satoshi);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 8px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 800ms ease, transform 800ms ease;
  }

  :global(.snapPage.isActive) .project-tile:nth-child(1) .project-meta {
    opacity: 1; transform: translateY(0); transition-delay: 850ms;
  }
  :global(.snapPage.isActive) .project-tile:nth-child(1) .project-description {
    opacity: 1; transform: translateY(0); transition-delay: 1000ms;
  }
  :global(.snapPage.isActive) .project-tile:nth-child(2) .project-meta {
    opacity: 1; transform: translateY(0); transition-delay: 960ms;
  }
  :global(.snapPage.isActive) .project-tile:nth-child(2) .project-description {
    opacity: 1; transform: translateY(0); transition-delay: 1110ms;
  }

  /* ========================
     TAGS — scale-pop spring, staggered per card
     Card 1: 5 tags from t=1150ms, 45ms apart
     Card 2: 4 tags from t=1260ms, 45ms apart
     ======================== */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: var(--font-satoshi);
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    background: transparent;
    border: 1px solid rgba(29, 29, 29, 0.2);
    border-radius: 100px;
    padding: 3px 10px;
    letter-spacing: 0.01em;
    opacity: 0;
    transform: scale(0.65);
    transition:
      opacity  550ms cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 550ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(.snapPage.isActive) .project-tile:nth-child(1) .tag:nth-child(1) { opacity:1; transform:scale(1); transition-delay:1150ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(1) .tag:nth-child(2) { opacity:1; transform:scale(1); transition-delay:1195ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(1) .tag:nth-child(3) { opacity:1; transform:scale(1); transition-delay:1240ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(1) .tag:nth-child(4) { opacity:1; transform:scale(1); transition-delay:1285ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(1) .tag:nth-child(5) { opacity:1; transform:scale(1); transition-delay:1330ms; }

  :global(.snapPage.isActive) .project-tile:nth-child(2) .tag:nth-child(1) { opacity:1; transform:scale(1); transition-delay:1260ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(2) .tag:nth-child(2) { opacity:1; transform:scale(1); transition-delay:1305ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(2) .tag:nth-child(3) { opacity:1; transform:scale(1); transition-delay:1350ms; }
  :global(.snapPage.isActive) .project-tile:nth-child(2) .tag:nth-child(4) { opacity:1; transform:scale(1); transition-delay:1395ms; }

  @media (max-width: 767px) {
    .projects-grid { grid-template-columns: 1fr; }

    /* On mobile single column, both cards slide up instead */
    .project-tile:nth-child(1),
    .project-tile:nth-child(2) {
      transform: translateY(24px);
    }
  }
</style>
