---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    title: "Pyko Canada — AI-Powered Education Platform",
    year: "2025 – Present",
    stack: "Python · TypeScript · FastAPI · MongoDB Atlas · AWS",
    description: "Founding Engineer on a 5-person team. Shipped Canvas LMS integration, an AI copilot reducing student setup time by 85%, and a student performance analytics layer with peer benchmarking.",
    color: "#1a1a2e",
    accent: "#214BB7",
    image: "/pyko.jpg",
  },
  {
    title: "PakUni — Centralized Admissions Platform",
    year: "2026",
    stack: "Python · JavaScript · FastAPI · MongoDB",
    description: "MVP platform for Pakistani students to create one reusable profile and submit to multiple universities. Reduced duplicated data entry by ~78% across 5 applications.",
    color: "#214BB7",
    accent: "#4a6fd4",
  },
];
---

<div class="projects-content">
  <div data-reveal data-delay="0">
    <SectionLabel text="Projects" />
  </div>

  <h2 class="projects-heading" data-reveal data-delay="1">
    Building Products That Solve Real Problems
  </h2>

  <div class="projects-grid" data-reveal data-delay="2">
    {projects.map((p) => (
      <div class="project-tile">
        <div class="project-image-wrap" style={`background: ${p.color};`}>
          {p.image ? (
            <img src={p.image} alt={p.title} class="project-img" />
          ) : (
            <div class="project-placeholder">
              <div class="placeholder-lines">
                <div class="ph-line ph-line-wide" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-mid" style={`background: ${p.accent};`}></div>
                <div class="ph-line ph-line-short" style={`background: ${p.accent};`}></div>
              </div>
            </div>
          )}
        </div>
        <div class="project-meta">
          <span class="project-title">{p.title}</span>
          <span class="project-year muted">{p.year}</span>
        </div>
        <p class="project-description muted">{p.description}</p>
        <span class="project-stack">{p.stack}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .projects-content {
    width: 100%;
  }

  .projects-heading {
    font-size: clamp(31px, 3.9vw, 44px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 620px;
    margin-bottom: 32px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .project-tile {
    display: flex;
    flex-direction: column;
  }

  .project-image-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 16px;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .project-tile:hover .project-image-wrap {
    opacity: 0.9;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .placeholder-lines {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 40%;
  }

  .ph-line {
    height: 4px;
    border-radius: 2px;
    opacity: 0.45;
  }

  .ph-line-wide  { width: 100%; }
  .ph-line-mid   { width: 70%; }
  .ph-line-short { width: 50%; }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 8px;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .project-year {
    font-size: 15px;
    flex-shrink: 0;
  }

  .project-description {
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 8px;
  }

  .project-stack {
    font-size: 13px;
    color: var(--accent);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  @media (max-width: 767px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
