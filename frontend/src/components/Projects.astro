---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    title: "[Redesign] - Enstack Landing Page",
    year: "2024",
    image: "/assets/project-1.jpg",
  },
  {
    title: "Kursinan - Furniture Website Design",
    year: "2024",
    image: "/assets/project-2.jpg",
  },
  {
    title: "Kentung - Furniture Website Design",
    year: "2024",
    image: "/assets/project-4.jpg",
  },
  {
    title: "ARTVISTA GALLERY - Art Gallery Website",
    year: "2024",
    image: "/assets/project-5.jpg",
  },
];
---

<section id="projects" class="section projects">
  <div class="container">
    <SectionLabel text="Projects" />

    <h2 class="projects-heading">
      Showcasing Our Success Stories Through
      Thoughtfully Crafted Solutions
    </h2>

    <div class="projects-grid">
      <!-- Row 1: 2 tiles -->
      <div class="project-row project-row-2">
        {projects.slice(0, 2).map((p) => (
          <div class="project-tile">
            <div class="project-image-wrap">
              <img src={p.image} alt={p.title} class="project-image" />
            </div>
            <div class="project-meta">
              <span class="project-title">{p.title}</span>
              <span class="project-year">{p.year}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- Row 2: 2 tiles -->
      <div class="project-row project-row-2">
        {projects.slice(3, 5).map((p) => (
          <div class="project-tile">
            <div class="project-image-wrap">
              <img src={p.image} alt={p.title} class="project-image" />
            </div>
            <div class="project-meta">
              <span class="project-title">{p.title}</span>
              <span class="project-year">{p.year}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .projects-heading {
    font-size: clamp(31px, 3.9vw, 44px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 620px;
    margin-bottom: 48px;
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .project-row {
    display: grid;
    gap: 24px;
  }

  .project-row-2 {
    grid-template-columns: 1fr 1fr;
  }

  .project-row-1 {
    grid-template-columns: 1fr;
  }

  .project-tile-full {
    max-width: 600px;
    margin: 0 auto;
  }

  .project-image-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 16px;
    background: #ddd;
    aspect-ratio: 4 / 3;
  }

  .project-tile-full .project-image-wrap {
    aspect-ratio: 16 / 10;
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-tile:hover .project-image {
    transform: scale(1.03);
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .project-year {
    font-size: 15px;
    color: var(--muted);
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .project-row-2 {
      grid-template-columns: 1fr;
    }

    .project-tile-full {
      max-width: 100%;
    }
  }
</style>
