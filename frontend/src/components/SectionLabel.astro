---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<span class="section-label">{text}</span>

<style>
  .section-label {
    display: inline-block;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 20px;
    font-weight: 400;
    color: var(--text);
    background: var(--card);
    border: 1px solid rgba(29, 29, 29, 0.15);
    border-radius: 999px;
    padding: 6px 16px;
    margin-bottom: 20px;
  }
</style>
