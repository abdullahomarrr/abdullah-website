---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Abdullah Omar | Portfolio",
  description = "Project case study by Abdullah Omar, software engineer.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/logo.png" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  /* ── Page exit — drops away with gravity ── */
  @keyframes pageExitDown {
    from { transform: translateY(0);    opacity: 1; }
    to   { transform: translateY(64px); opacity: 0; }
  }

  body.page-exiting {
    animation: pageExitDown 350ms cubic-bezier(0.4, 0, 1, 1) forwards;
    pointer-events: none;
    overflow: hidden;
  }
</style>

<script>
  // Intercept internal link clicks — play exit drop before navigating
  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null;
    if (!link) return;

    const href = link.getAttribute('href') ?? '';

    // Skip: external URLs, anchors, mailto/tel, new-tab links
    if (
      !href ||
      href.startsWith('#') ||
      href.startsWith('mailto:') ||
      href.startsWith('tel:') ||
      href.startsWith('http') ||
      href.startsWith('//') ||
      link.target === '_blank'
    ) return;

    e.preventDefault();
    document.body.classList.add('page-exiting');

    // Navigate when animation ends; 400ms timeout as hard fallback
    const fallback = setTimeout(() => { window.location.href = href; }, 400);
    document.body.addEventListener('animationend', () => {
      clearTimeout(fallback);
      window.location.href = href;
    }, { once: true });
  });
</script>
