---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
---

<ProjectLayout title="Freelance Designer | Abdullah Omar">

  <!-- TOP BAR -->
  <div class="topbar">
    <div class="topbar-inner">
      <a href="/#experience" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 13L5 8L10 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back to Experience
      </a>
      <a href="/" class="brand-link" aria-label="Home">
        <img src="/logo.png" alt="Abdullah Omar" class="brand-logo" />
      </a>
    </div>
  </div>

  <main class="page-main">

    <!-- ROLE HEADER -->
    <header class="exp-header anim" style="--i:0">
      <p class="meta-company">Self-Employed</p>
      <h1 class="meta-role">Freelance & Enterprise Designer</h1>
      <p class="meta-location">Toronto, Ontario · 2022 – 2024</p>
      <p class="meta-tools">Photoshop · Blender · Premiere Pro · After Effects · DaVinci Resolve</p>
    </header>

    <!-- CONTENT -->
    <div class="content anim" style="--i:1">
      <div class="divider"></div>
      <ul class="bullet-list" role="list">
        <li>Delivered 50+ high-performing YouTube thumbnails and a high volume of ad creatives for esports orgs and creators, balancing speed with brand consistency across platforms.</li>
        <li>Collaborated with creators and organizations totaling 6,000,000+ subscribers/followers, producing thumbnails and social ad creatives and iterating quickly based on feedback.</li>
        <li>Managed a rapid iteration cycle with a typical ~2-day turnaround, refining designs from client feedback and shipping deadline-driven assets.</li>
        <li>Built long-term client relationships with 15–20 repeat creators, including select full brand refreshes (templates, banners, promo graphics) aligned to consistent style guides.</li>
      </ul>
    </div>

  </main>

</ProjectLayout>

<!-- Lock body to viewport, no scrolling on this page -->
<style is:global>
  body {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
</style>

<style>
  /* ── Animations ─────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .anim {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i, 0) * 0.12s);
  }

  /* ── Top bar ────────────────────────────── */
  .topbar {
    flex-shrink: 0;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .topbar-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-satoshi);
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.15s ease;
  }

  .back-link:hover { color: var(--text); }

  .back-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .brand-link { display: flex; align-items: center; }
  .brand-logo { height: 48px; width: auto; }

  /* ── Page layout ────────────────────────── */
  .page-main {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-width: 1100px;
    padding: 0 40px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Role header ────────────────────────── */
  .exp-header {
    flex-shrink: 0;
    padding-top: 36px;
    margin-bottom: 24px;
  }

  .meta-company {
    font-family: var(--font-satoshi);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .meta-role {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4.5vw, 58px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 12px;
  }

  .meta-location {
    font-family: var(--font-satoshi);
    font-size: 14px;
    color: var(--muted);
    line-height: 1.5;
  }

  .meta-tools {
    font-family: var(--font-satoshi);
    font-size: 13px;
    color: var(--muted);
    margin-top: 6px;
    opacity: 0.75;
  }

  /* ── Content ────────────────────────────── */
  .content {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-width: 680px;
  }

  .divider {
    flex-shrink: 0;
    border-top: 1px solid var(--border);
    margin-bottom: 28px;
  }

  .bullet-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 0;
    margin: 0;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 32px;
  }

  .bullet-list::-webkit-scrollbar { display: none; }

  .bullet-list li {
    font-family: var(--font-satoshi);
    font-size: 15px;
    line-height: 1.72;
    color: var(--text);
    padding-left: 20px;
    position: relative;
  }

  .bullet-list li::before {
    content: "–";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--muted);
    font-weight: 400;
  }

  /* ── Responsive ─────────────────────────── */
  @media (max-width: 1023px) {
    .page-main { padding: 0 32px; }
    .topbar-inner { padding: 0 32px; }
  }

  @media (max-width: 767px) {
    .page-main { padding: 0 20px; overflow-y: auto; }
    .topbar-inner { padding: 0 20px; }
    .exp-header { padding-top: 32px; }
    .content { overflow: visible; }
    .bullet-list { overflow: visible; padding-bottom: 0; }
  }
</style>
